# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
build/
dist/
*.egg-info/

# Jupyter
.ipynb_checkpoints/
*.nbconvert.ipynb

# OS / IDE
.DS_Store
.idea/
.vscode/
*.swp
Thumbs.db

# Data files — exclude everything in data/ by default,
# then explicitly track ONLY CC_GENERAL (the one not publicly downloadable).
# Online Shoppers and Online Retail II auto-download from UCI on first use.
data/*
!data/.gitkeep
!data/CC_GENERAL.csv

# Avoid committing temporary results that are easily regenerated
results/figures/*.png
results/figures/*.pdf
!results/figures/.gitkeep
results/tables/*.csv
!results/tables/.gitkeep

# Gradio cache
gradio_cached_examples/
flagged/
